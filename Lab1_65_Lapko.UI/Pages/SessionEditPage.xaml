<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab1_65_Lapko.UI.Pages.SessionEditPage"
             Title="{Binding Title}">
    <Grid>
        <ScrollView IsEnabled="{Binding IsNotBusy}">
            <VerticalStackLayout Padding="16" Spacing="12">
                <Label Text="Topic" FontAttributes="Bold" />
                <Entry Text="{Binding Topic}" Placeholder="Session topic" />

                <Label Text="Type" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding Types}" SelectedItem="{Binding Type}" />

                <Label Text="Date" FontAttributes="Bold" />
                <DatePicker Date="{Binding Date}" />

                <Label Text="Start Time" FontAttributes="Bold" />
                <TimePicker Time="{Binding StartTime}" />

                <Label Text="End Time" FontAttributes="Bold" />
                <TimePicker Time="{Binding EndTime}" />

                <HorizontalStackLayout Spacing="12" Margin="0,16,0,0">
                    <Button Text="Save" Command="{Binding SaveCommand}" WidthRequest="120" />
                    <Button Text="Cancel" Command="{Binding CancelCommand}" WidthRequest="120" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="DodgerBlue"
                           WidthRequest="48" HeightRequest="48"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>
