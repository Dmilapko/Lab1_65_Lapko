<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab1_65_Lapko.UI.Pages.SubjectsPage"
             Title="Subjects">
    <CollectionView x:Name="SubjectsCollection"
                    SelectionMode="Single"
                    SelectionChanged="OnSubjectSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Stroke="LightGray" StrokeThickness="1"
                        Padding="12" Margin="8,4"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="{Binding EctsCredits, StringFormat='ECTS: {0}'}" FontSize="14" />
                            <Label Text="{Binding Area}" FontSize="14" TextColor="Gray" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
